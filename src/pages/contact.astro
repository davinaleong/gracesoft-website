---
import BaseLayout from '../layouts/BaseLayout.astro';

const status = Astro.url.searchParams.get('status');
---
<BaseLayout
	title="Contact"
	description="Contact GraceSoft to discuss your web app idea, UX challenges, or system improvements with a clear, structured approach."
>
	<main class="contact-page">
		<section class="title-section contact-hero relative isolate overflow-hidden text-white px-4 py-20 sm:py-24 lg:py-28">
			<div class="container mx-auto max-w-5xl space-y-5 text-center reveal rise">
				<h1 class="font-serif text-3xl leading-tight sm:text-4xl lg:text-6xl">Let's Build Something Meaningful</h1>
				<p class="mx-auto max-w-3xl text-sm text-gs-purple-100 sm:text-base lg:text-xl">Have an idea, a problem, or a system that needs improvement? I would love to hear more about what you are working on.</p>
			</div>
		</section>

		<section class="contact-main-section px-4 py-14 sm:py-16 lg:py-20">
			<div class="container mx-auto max-w-4xl grid gap-4 sm:gap-5 grid-cols-1">
				<article class="contact-card reveal rise delay-1 space-y-4">
					<h2 class="font-serif text-2xl sm:text-3xl">Start a Conversation</h2>
					{
						status === 'sent' && (
							<p class="form-status form-status-success" role="status">Thanks for your message. I will get back to you soon.</p>
						)
					}
					{
						status === 'blocked' && (
							<p class="form-status form-status-error" role="alert">Submission was blocked. Please try again after a few seconds.</p>
						)
					}
					{
						status === 'invalid' && (
							<p class="form-status form-status-error" role="alert">Please check your form details and try again.</p>
						)
					}
					{
						status === 'error' && (
							<p class="form-status form-status-error" role="alert">Something went wrong sending your message. Please try again later.</p>
						)
					}
					<p class="text-sm sm:text-base text-gs-black-700">Share a few details about your project or what you need help with, and I will get back to you as soon as possible.</p>
					<form class="contact-form" method="POST" action="/api/contact" accept-charset="UTF-8">
						<div class="contact-field">
							<label for="name">Name</label>
							<input id="name" name="name" type="text" autocomplete="name" maxlength="120" required />
						</div>

						<div class="contact-field">
							<label for="email">Email</label>
							<input id="email" name="email" type="email" inputmode="email" autocomplete="email" maxlength="180" required />
						</div>

						<div class="contact-field">
							<label for="subject">Subject</label>
							<select id="subject" name="subject" required>
								<option value="" selected disabled>Select a subject</option>
								<option value="web-application-development">Web Application Development</option>
								<option value="ux-ui-design">UX/UI Design</option>
								<option value="system-architecture">System Architecture</option>
								<option value="technical-consulting">Technical Consulting</option>
								<option value="other">Other</option>
							</select>
						</div>

						<div class="contact-field">
							<label for="message">Message</label>
							<textarea id="message" name="message" rows="6" minlength="20" maxlength="3000" required></textarea>
						</div>

						<div class="contact-honeypot" aria-hidden="true">
							<label for="company">Company</label>
							<input id="company" name="company" type="text" tabindex="-1" autocomplete="off" />
						</div>

						<input id="formLoadedAt" name="form_loaded_at" type="hidden" value="" />
						<input id="formElapsedMs" name="form_elapsed_ms" type="hidden" value="" />

						<button type="submit" class="contact-submit inline-flex items-center justify-center font-semibold text-white bg-gs-purple-600 rounded-md px-5 py-3 shadow-sm transition-transform duration-300 hover:-translate-y-0.5 hover:opacity-90">Send Message</button>
					</form>
				</article>
			</div>
		</section>

		<section class="cta-section px-4 py-16 sm:py-20 lg:py-24">
			<div class="container mx-auto max-w-4xl space-y-6 sm:space-y-8 text-center cta-panel reveal rise">
				<h2 class="font-serif text-3xl leading-tight sm:text-4xl lg:text-5xl">Ready When You Are</h2>
				<p class="text-sm sm:text-base lg:text-lg">Tell me what you are building, and we will map the right path forward.</p>
				<p>
					<a href="/contact" class="inline-flex items-center justify-center font-semibold text-gs-purple-700 bg-white rounded-md px-5 py-3 shadow-sm transition-transform duration-300 hover:-translate-y-0.5 hover:opacity-90">Send an Email &rarr;</a>
				</p>
			</div>
		</section>
	</main>
</BaseLayout>

<script is:inline>
	const contactForm = document.querySelector('.contact-form');

	if (contactForm) {
		const loadedAtField = contactForm.querySelector('#formLoadedAt');
		const elapsedMsField = contactForm.querySelector('#formElapsedMs');
		const honeypotField = contactForm.querySelector('#company');
		const loadedAt = Date.now();

		if (loadedAtField) loadedAtField.value = String(loadedAt);

		contactForm.addEventListener('submit', (event) => {
			const elapsedMs = Date.now() - loadedAt;
			if (elapsedMsField) elapsedMsField.value = String(elapsedMs);

			if ((honeypotField && honeypotField.value.trim() !== '') || elapsedMs < 3000) {
				event.preventDefault();
				alert('Submission blocked. Please wait a moment and try again.');
			}
		});
	}
</script>