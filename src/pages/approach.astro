---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Approach">
    <main class="approach-page">
        <section class="title-section approach-hero relative isolate overflow-hidden text-white px-4 py-20 sm:py-24 lg:py-28">
            <div class="container mx-auto max-w-5xl space-y-5 text-center reveal rise">
                <h1 class="sr-only">Approach</h1>
                <p class="font-serif text-3xl leading-tight sm:text-4xl lg:text-6xl">A Structured Approach to Building Better Systems</p>
                <p class="mx-auto max-w-3xl text-sm text-gs-purple-100 sm:text-base lg:text-xl">We guide every project through a clear sequence so product decisions stay intentional, user-focused, and technically resilient.</p>
            </div>
        </section>

        <section class="discover-section px-4 py-14 sm:py-16 lg:py-20">
            <div class="container mx-auto max-w-6xl space-y-6">
                <h2 class="font-serif text-2xl sm:text-3xl lg:text-4xl text-center reveal rise">1. Discover</h2>
                <div class="approach-step-card reveal rise delay-1">
                    <ul class="space-y-3 text-sm sm:text-base lg:text-lg">
                        <li>Stakeholder goals</li>
                        <li>User problems</li>
                        <li>Business context</li>
                    </ul>
                </div>
            </div>
        </section>

        <section class="define-section px-4 py-14 sm:py-16 lg:py-20">
            <div class="container mx-auto max-w-6xl space-y-6">
                <h2 class="font-serif text-2xl sm:text-3xl lg:text-4xl text-center reveal rise">2. Define</h2>
                <div class="approach-step-card reveal rise delay-1">
                    <ul class="space-y-3 text-sm sm:text-base lg:text-lg">
                        <li>User journeys</li>
                        <li>System architecture</li>
                        <li>Technical decisions</li>
                    </ul>
                </div>
            </div>
        </section>

        <section class="build-section px-4 py-14 sm:py-16 lg:py-20">
            <div class="container mx-auto max-w-6xl space-y-6">
                <h2 class="font-serif text-2xl sm:text-3xl lg:text-4xl text-center reveal rise">3. Build</h2>
                <div class="approach-step-card reveal rise delay-1">
                    <ul class="space-y-3 text-sm sm:text-base lg:text-lg">
                        <li>Clean, maintainable code</li>
                        <li>Scalable architecture</li>
                        <li>Iterative development</li>
                    </ul>
                </div>
            </div>
        </section>

        <section class="refine-section px-4 py-14 sm:py-16 lg:py-20">
            <div class="container mx-auto max-w-6xl space-y-6">
                <h2 class="font-serif text-2xl sm:text-3xl lg:text-4xl text-center reveal rise">4. Refine</h2>
                <div class="approach-step-card reveal rise delay-1">
                    <ul class="space-y-3 text-sm sm:text-base lg:text-lg">
                        <li>Feedback loops</li>
                        <li>Performance improvements</li>
                        <li>Long-term support</li>
                    </ul>
                </div>
                <p class="text-center text-gs-purple-600 font-semibold text-base sm:text-lg lg:text-xl reveal rise delay-2">This cycle keeps your system useful now and adaptable later.</p>
            </div>
        </section>
    </main>
</BaseLayout>